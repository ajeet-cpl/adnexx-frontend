# Local development only — gitignored, never committed.
# Vite proxies /api/* to VITE_PROXY_TARGET (avoids CORS).
# Change to http://localhost:8080 when running the backend locally.
VITE_PROXY_TARGET=http://ec2-13-60-234-74.eu-north-1.compute.amazonaws.com:8080
# VITE_PROXY_TARGET=https://aodbapi.corepeelers.com
# VITE_PROXY_TARGET=http://localhost:8080


# Leave EMPTY — browser calls /api/* which Vite proxies above.
VITE_API_URL=

# Health check path used by the Vite /api/ping dev endpoint.
VITE_HEALTH_PATH=/api/v1/actuator/health
