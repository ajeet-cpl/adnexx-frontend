# ============================================================
# Environment variable reference
# Copy to .env.development or .env.production as appropriate
# ============================================================

# ── Development only ─────────────────────────────────────────

# Backend URL that the Vite dev server proxies /api/* to.
# Change to your local or remote backend address.
VITE_PROXY_TARGET=http://localhost:8080

# Leave EMPTY in dev — browser calls /api/* which Vite proxies above (avoids CORS).
VITE_API_URL=

# Health check path appended to VITE_PROXY_TARGET for the /api/ping dev endpoint
VITE_HEALTH_PATH=/api/v1/actuator/health

# ── Production only ──────────────────────────────────────────

# Direct backend URL used by the built bundle (no proxy in prod)
# VITE_API_URL=https://your-backend.example.com

